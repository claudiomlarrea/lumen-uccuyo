# Copiar a .streamlit/secrets.toml (NO subir a GitHub).
# Por defecto la integración está DESACTIVADA.

[lumen_integracion]
habilitada = false
correo_responsable_default = "prototipo.lumen@uccuyo.edu.ar"

# Descomentar y completar solo al activar escritura en planillas productivas:
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "lumen-sheets@....iam.gserviceaccount.com"
# client_id = "..."
